---
import Bi from "../components/Bi.astro";
import { DISCOVER_PAGE, FOOTER, SITE, THEMES_PAGE } from "../lib/ui";

interface Props {
  title: string;
  description?: string;
  /** 相對於網站根路徑的社群預覽圖 */
  ogImage?: string;
  /** 不讓搜尋引擎索引（例如預覽環境） */
  noIndex?: boolean;
}
const {
  title,
  description = SITE.desc,
  ogImage = "/og-default.svg",
  noIndex = false,
} = Astro.props;

const siteBase = Astro.site ?? new URL("/", Astro.url);
const canonicalUrl = new URL(Astro.url.pathname + Astro.url.search, siteBase);
const ogImageUrl = new URL(ogImage, siteBase);
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:locale" content="zh_TW" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/fin-dash.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Main navigation">
        <a class="brand" href="/">{SITE.name}</a>
        <div class="nav-links">
          <a href="/sectors"><Bi zh="產業" en="Industries" /></a>
          <a href="/themes">{THEMES_PAGE.nav}</a>
          <a href="/discover">{DISCOVER_PAGE.nav}</a>
          <a href="/wiki"><Bi zh="Wikilink 索引" en="Wikilink hub" /></a>
          <a href="/graph"><Bi zh="供應鏈網路圖" en="Supply-chain graph" /></a>
        </div>
      </nav>
    </header>
    <main class="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p class="footer-disclaimer" role="note">{FOOTER.disclaimer}</p>
      <p class="footer-source">
        <Bi zh="資料來源" en="Data source" />：<a
          href="https://github.com/meishihna/myTWstock"
          target="_blank"
          rel="noopener">GitHub · meishihna / TWstock</a
        >
      </p>
    </footer>
  </body>
</html>
