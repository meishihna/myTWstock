---
import Layout from "../../layouts/Layout.astro";
import Bi from "../../components/Bi.astro";
import ChartBars from "../../components/ChartBars.astro";
import MarginChartToggle from "../../components/MarginChartToggle.astro";
import RevenueChartToggle from "../../components/RevenueChartToggle.astro";
import QuoteStrip from "../../components/QuoteStrip.astro";
import RelationSummary from "../../components/RelationSummary.astro";
import ValuationSection from "../../components/ValuationSection.astro";
import BusinessIntroCard from "../../components/BusinessIntroCard.astro";
import FinancialDashboard from "../../components/FinancialDashboard.astro";
import { normalizeIndustryTypeForDashboard } from "../../lib/industryConfig";
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";
import {
  annualRevenueSeriesFromJson,
  quarterlyRevGmSeriesPairFromJson,
  tailNullableSeries,
  tailNullableSeriesPair,
  type FinancialsJson,
  type NullableFinancialSeries,
} from "../../lib/financialsJson";
import { renderReportMarkdown } from "../../lib/renderReport";
import {
  addHeadingAnchors,
  chronologicalSeries,
  extractRelatedTw,
  extractToc,
  parseAnnualGrossMargin,
  parseAnnualRevenue,
  parseQuarterlyGrossMargin,
  parseQuarterlyRevenue,
  parseRelationBlocks,
  parseReportSummary,
  mergeValuationJsonWithMarkdown,
  parseValuation,
  valuationFromFinancialsJson,
  stripRelationSectionsForBody,
  stripValuationMarkdownSubsection,
  extractBusinessIntroMarkdown,
  stripBusinessIntroForBody,
  stripBusinessIntroKpiDuplicateMeta,
  marginBarScale,
  maxAbsGrowthScale,
  maxAbsPptScale,
  periodOverPeriodGrowthPct,
  periodOverPeriodMarginPpt,
  tailRevenueSeries,
  type ValuationParsed,
} from "../../lib/parseReport";
import { showFinancialDashboard } from "../../lib/financialDashboard";
import {
  readRevenueMixForTicker,
  revenueStructureForRelationTab,
  type BizRevenueRow,
} from "../../lib/businessIntro";
import { REPORT, SITE } from "../../lib/ui";

/** 即時 Yahoo 走勢／延遲行情：每次請求 SSR，不在 build 時預抓 */
export const prerender = false;

/** `web/` 目錄（不依賴 process.cwd，避免從 repo 根目錄啟動 dev 時路徑錯到找不到 enrichment） */
const __reportDir = path.dirname(fileURLToPath(import.meta.url));
const webRoot = path.resolve(__reportDir, "..", "..", "..");
const repoRoot = path.resolve(__reportDir, "..", "..", "..", "..");
const idxPath = path.join(webRoot, "public", "data", "reports-index.json");

const { ticker } = Astro.params;
const idx = JSON.parse(fs.readFileSync(idxPath, "utf8"));
const nameToTicker = idx.nameToTicker as Record<string, string>;
const meta = idx.byTicker[ticker!] as
  | {
      ticker: string;
      name: string;
      sector: string;
      relPath: string;
      sectorSlug: string;
    }
  | undefined;

if (!meta) {
  return new Response(null, { status: 404 });
}

const mdPath = path.join(repoRoot, "Pilot_Reports", ...meta.relPath.split("/"));
const raw = fs.readFileSync(mdPath, "utf8");
const baseStripped = stripValuationMarkdownSubsection(
  stripRelationSectionsForBody(raw),
);
const businessIntroMdRaw = extractBusinessIntroMarkdown(baseStripped);
let businessIntroMd = businessIntroMdRaw
  ? stripBusinessIntroKpiDuplicateMeta(businessIntroMdRaw)
  : null;
if (
  businessIntroMd &&
  !businessIntroMd.replace(/^##\s+業務簡介\s*\r?\n?/m, "").trim()
) {
  businessIntroMd = null;
}

const rawBody = stripBusinessIntroForBody(baseStripped);
const toc = extractToc(rawBody);

const hubJsonPath = path.join(webRoot, "public/data/wikilink-hub-top500.json");
const stubsJsonPath = path.join(webRoot, "public/data/wikilink-stubs.json");
const labelToWikiSlug: Record<string, string> = {};
if (fs.existsSync(stubsJsonPath)) {
  const st = JSON.parse(fs.readFileSync(stubsJsonPath, "utf8"));
  for (const s of st.stubs ?? []) {
    for (const lab of s.labels ?? []) {
      if (!(lab in labelToWikiSlug)) labelToWikiSlug[lab] = s.slug;
    }
  }
}
if (fs.existsSync(hubJsonPath)) {
  const hub = JSON.parse(fs.readFileSync(hubJsonPath, "utf8"));
  for (const e of hub.entries ?? []) {
    labelToWikiSlug[e.label] = e.slug;
  }
}

let html = renderReportMarkdown(rawBody, nameToTicker, labelToWikiSlug);
html = addHeadingAnchors(html, toc);

const summaryMd = parseReportSummary(raw);
const relationBlocks = parseRelationBlocks(raw);
const relatedTw = extractRelatedTw(raw, nameToTicker);

/** 柱狀圖近 8 年／近 32 季（與 financials JSON 上限一致；內文季表由 report-financial-tables.js 重建）。 */
const CHART_ANNUAL_PERIODS = 8;
const CHART_QUARTERLY_PERIODS = 32;

const revChrono = chronologicalSeries(parseAnnualRevenue(raw));
const revChronoChart = revChrono
  ? tailRevenueSeries(revChrono, CHART_ANNUAL_PERIODS)
  : null;
const revMax = revChronoChart
  ? Math.max(...revChronoChart.values.map((v) => Math.abs(v)), 1)
  : 1;

const qRevChrono = chronologicalSeries(parseQuarterlyRevenue(raw));

const annGmChrono = chronologicalSeries(parseAnnualGrossMargin(raw));
const annGmChronoChart = annGmChrono
  ? tailRevenueSeries(annGmChrono, CHART_ANNUAL_PERIODS)
  : null;
const annGmMax = annGmChronoChart
  ? marginBarScale(annGmChronoChart.values)
  : 100;

const qGmChrono = chronologicalSeries(parseQuarterlyGrossMargin(raw));

const annGmPpt =
  annGmChronoChart && annGmChronoChart.values.length >= 2
    ? periodOverPeriodMarginPpt(annGmChronoChart.values)
    : null;
const annGmPptMax = annGmPpt ? maxAbsPptScale(annGmPpt) : 1;

const finStorePath = path.join(
  repoRoot,
  "data/financials_store",
  `${ticker}.json`
);
const finPublicPath = path.join(
  webRoot,
  "public/data/financials",
  `${ticker}.json`
);
let financialsJson: FinancialsJson | null = null;
const finReadPath = fs.existsSync(finStorePath)
  ? finStorePath
  : fs.existsSync(finPublicPath)
    ? finPublicPath
    : null;
if (finReadPath) {
  try {
    financialsJson = JSON.parse(fs.readFileSync(finReadPath, "utf8"));
  } catch {
    financialsJson = null;
  }
}

const revenueMix = readRevenueMixForTicker(repoRoot, webRoot, ticker!);

/** 營收結構置於下方「關係摘要」第四膠囊（供應商後、競爭對手前） */
let revenueStructureForRelation: {
  yearLabel: string | null;
  revenueRows: BizRevenueRow[];
  revenueGeo: string | null;
} | null = null;
if (businessIntroMd) {
  const bodyMd = businessIntroMd.replace(/^##\s+業務簡介\s*\r?\n?/m, "").trim();
  revenueStructureForRelation = revenueStructureForRelationTab(bodyMd, revenueMix);
} else {
  revenueStructureForRelation = revenueStructureForRelationTab("", revenueMix);
}

const finDashIndustryType = normalizeIndustryTypeForDashboard(
  financialsJson?.industryType ?? "general",
);

/**
 * 報告頁「上市／上櫃／興櫃」徽章：由 financials_store JSON 的 exchange + listingStatus 推導。
 * emerging 優先；上市／上櫃須同時滿足 listingStatus === listed。
 */
function deriveListingBadge(
  exchange: string | null,
  listingStatus: string | null,
): { label: string; variant: "twse" | "tpex" | "emerging" } | null {
  if (listingStatus === "emerging") {
    return { label: "興櫃", variant: "emerging" };
  }
  if (listingStatus !== "listed") {
    return null;
  }
  if (exchange === "TWSE") {
    return { label: "上市", variant: "twse" };
  }
  if (exchange === "TPEx") {
    return { label: "上櫃", variant: "tpex" };
  }
  return null;
}

const fj = financialsJson as Record<string, unknown> | null;
const listingEx = {
  exchange: fj && typeof fj.exchange === "string" ? (fj.exchange as string) : null,
  listingStatus:
    fj && typeof fj.listingStatus === "string" ? (fj.listingStatus as string) : null,
};
const listingBadge = deriveListingBadge(listingEx.exchange, listingEx.listingStatus);

const fmtMCap = (v: unknown): string | null => {
  if (v == null) return null;
  const n = typeof v === "number" ? v : Number(v);
  return Number.isFinite(n) ? `${n.toLocaleString("zh-TW")} 百萬台幣` : null;
};
const summary = {
  board: (fj?.sector as string) ?? summaryMd.board ?? null,
  industry: (fj?.industry as string) ?? summaryMd.industry ?? null,
  marketCap: fmtMCap(fj?.marketCap) ?? summaryMd.marketCap ?? null,
  enterpriseValue: fmtMCap(fj?.enterpriseValue) ?? summaryMd.enterpriseValue ?? null,
  note: summaryMd.note ?? null,
};

/** 板塊／產業：null、空字串、N/A 顯示為「—」，不顯示字面 N/A */
function metaDisplayField(v: unknown): string {
  if (v == null) return "—";
  const s = String(v).trim();
  if (!s) return "—";
  const u = s.toUpperCase();
  if (u === "N/A" || u === "NA" || u === "NONE") return "—";
  return s;
}
const sectorDisplay = metaDisplayField(summary.board);
const industryDisplay = metaDisplayField(summary.industry);

const mdValuation = parseValuation(raw);
const valuation: ValuationParsed = fj?.valuation
  ? mergeValuationJsonWithMarkdown(
      valuationFromFinancialsJson(fj.valuation as Record<string, unknown>),
      mdValuation,
    )
  : mdValuation;

/** 季度表「累積合併」用；與 Markdown 單季表同期別對齊 */
const quarterlyYtdJsonForTable =
  financialsJson?.quarterlyYtd?.periods?.length &&
  financialsJson.quarterlyYtd.series
    ? JSON.stringify(financialsJson.quarterlyYtd)
    : "";
/** 年表 EPS 修正：以單季 EPS 加總對齊 Yahoo 年報誤植 */
const quarterlyBlockForAnnualEpsFix =
  financialsJson?.quarterly?.series?.EPS &&
  financialsJson.quarterly.periods?.length
    ? financialsJson.quarterly
    : financialsJson?.quarterlyCore?.series?.EPS &&
        financialsJson.quarterlyCore.periods?.length
      ? financialsJson.quarterlyCore
      : null;
const quarterlyJsonForReportTable = quarterlyBlockForAnnualEpsFix
  ? JSON.stringify(quarterlyBlockForAnnualEpsFix)
  : "";
/** 內文季表欄位：優先完整 quarterly（期數最多），供 report-financial-tables.js 重建（至多 32 欄） */
const quarterlyDisplayJsonForTable =
  financialsJson?.quarterly?.periods?.length && financialsJson.quarterly.series
    ? JSON.stringify(financialsJson.quarterly)
    : quarterlyJsonForReportTable;
const annualJsonForTable =
  financialsJson?.annual?.periods?.length && financialsJson.annual.series
    ? JSON.stringify(financialsJson.annual)
    : "";
const finDashOk = showFinancialDashboard(financialsJson);
const finDataUnavailable =
  financialsJson != null &&
  !(
    Array.isArray(financialsJson.annual?.periods) &&
    (financialsJson.annual?.periods?.length ?? 0) > 0
  );
const jsonAnnualRev = annualRevenueSeriesFromJson(financialsJson);
const jsonAnnualChart = jsonAnnualRev
  ? tailNullableSeries(jsonAnnualRev, CHART_ANNUAL_PERIODS)
  : null;
const mdAnnualLen = revChrono?.values.length ?? 0;
const jsonAnnualFinite =
  jsonAnnualRev?.values.filter((v) => v != null && Number.isFinite(v)).length ??
  0;
/** JSON 年度營收期數不少於 Markdown 表時只畫一張，避免重複 */
const useJsonForAnnualRevenue = Boolean(
  jsonAnnualRev &&
    jsonAnnualFinite >= 2 &&
    jsonAnnualRev.labels.length >= mdAnnualLen
);
const showJsonAnnualRev = useJsonForAnnualRevenue;
const showMarkdownAnnualRev = Boolean(
  revChrono &&
    revChrono.values.length > 0 &&
    !useJsonForAnnualRevenue
);
const jsonRevMax = showJsonAnnualRev && jsonAnnualChart
  ? Math.max(
      ...jsonAnnualChart.values
        .filter((v): v is number => v != null && Number.isFinite(v))
        .map((v) => Math.abs(v)),
      1
    )
  : 1;

const jsonRevGrowth =
  jsonAnnualChart && jsonAnnualChart.labels.length >= 2
    ? periodOverPeriodGrowthPct(jsonAnnualChart.values)
    : null;
const jsonRevGrowthMax = jsonRevGrowth
  ? maxAbsGrowthScale(jsonRevGrowth)
  : 1;

const annRevGrowth =
  revChronoChart && revChronoChart.values.length >= 2
    ? periodOverPeriodGrowthPct(revChronoChart.values)
    : null;
const annRevGrowthMax = annRevGrowth
  ? maxAbsGrowthScale(annRevGrowth)
  : 1;

const { rev: jsonQuarterlyRev, gm: jsonQuarterlyGm } =
  quarterlyRevGmSeriesPairFromJson(financialsJson);
const mdQuarterlyLen = qRevChrono?.labels.length ?? 0;
const mdQuarterlyFinite =
  qRevChrono?.values.filter((v) => Number.isFinite(v)).length ?? 0;
const jsonQuarterlyFinite =
  jsonQuarterlyRev?.values.filter((v) => v != null && Number.isFinite(v))
    .length ?? 0;
/** JSON 季資料：期數較 MD 多、或有效點較多、或達 8 季以上時優先 JSON（FinMind 補歷史） */
const useJsonQuarterlyCharts = Boolean(
  jsonQuarterlyRev &&
    jsonQuarterlyGm &&
    jsonQuarterlyRev.labels.length === jsonQuarterlyGm.labels.length &&
    jsonQuarterlyFinite >= 2 &&
    (jsonQuarterlyRev.labels.length >= mdQuarterlyLen ||
      jsonQuarterlyFinite >= mdQuarterlyFinite ||
      jsonQuarterlyRev.labels.length >= 8)
);

let chartQuarterlyRev: NullableFinancialSeries | null = null;
let chartQuarterlyGm: NullableFinancialSeries | null = null;
if (useJsonQuarterlyCharts && jsonQuarterlyRev && jsonQuarterlyGm) {
  const [r, g] = tailNullableSeriesPair(
    jsonQuarterlyRev,
    jsonQuarterlyGm,
    CHART_QUARTERLY_PERIODS
  );
  chartQuarterlyRev = r;
  chartQuarterlyGm = g;
} else {
  if (qRevChrono) {
    chartQuarterlyRev = tailNullableSeries(
      {
        labels: qRevChrono.labels,
        values: qRevChrono.values.map((v) => v),
      },
      CHART_QUARTERLY_PERIODS
    );
  }
  if (qGmChrono) {
    chartQuarterlyGm = tailNullableSeries(
      {
        labels: qGmChrono.labels,
        values: qGmChrono.values.map((v) => v),
      },
      CHART_QUARTERLY_PERIODS
    );
  }
}

const quarterlyRevChartOk = Boolean(
  chartQuarterlyRev &&
    chartQuarterlyRev.values.some((v) => v != null && Number.isFinite(v))
);
const quarterlyGmChartOk = Boolean(
  chartQuarterlyGm &&
    chartQuarterlyGm.values.some((v) => v != null && Number.isFinite(v))
);

const qRevGrowth =
  chartQuarterlyRev && chartQuarterlyRev.values.length >= 2
    ? periodOverPeriodGrowthPct(chartQuarterlyRev.values)
    : null;
const qRevGrowthMax = qRevGrowth ? maxAbsGrowthScale(qRevGrowth) : 1;

const qRevFinite = chartQuarterlyRev
  ? chartQuarterlyRev.values.filter(
      (v): v is number => v != null && Number.isFinite(v)
    )
  : [];
const qRevMax =
  qRevFinite.length > 0 ? Math.max(...qRevFinite.map((v) => Math.abs(v)), 1) : 1;

const qGmFinite = chartQuarterlyGm
  ? chartQuarterlyGm.values.filter(
      (v): v is number => v != null && Number.isFinite(v)
    )
  : [];
const qGmMax =
  qGmFinite.length > 0 ? marginBarScale(qGmFinite) : 100;

const qGmPpt =
  chartQuarterlyGm && chartQuarterlyGm.values.length >= 2
    ? periodOverPeriodMarginPpt(chartQuarterlyGm.values)
    : null;
const qGmPptMax = qGmPpt ? maxAbsPptScale(qGmPpt) : 1;

const sectorStatsPath = path.join(webRoot, "public/data/sector-stats.json");
let sectorPeerHintLine: string | null = null;
let sectorPeerRankLine: string | null = null;
if (fs.existsSync(sectorStatsPath)) {
  try {
    const ss = JSON.parse(fs.readFileSync(sectorStatsPath, "utf8"));
    const secBlock = ss.sectors?.[meta.sector];
    const revAgg = secBlock?.revenueLatest;
    const rank = secBlock?.revenuePercentileRank?.[meta.ticker];
    if (
      revAgg &&
      revAgg.n >= 3 &&
      revAgg.p25 != null &&
      revAgg.p50 != null &&
      revAgg.p75 != null
    ) {
      const fmtM = (x: number) =>
        x.toLocaleString("zh-TW", { maximumFractionDigits: 0 });
      sectorPeerHintLine = REPORT.sectorPeerRevenueHint.replace(
        "{p25}",
        fmtM(revAgg.p25)
      )
        .replace("{p50}", fmtM(revAgg.p50))
        .replace("{p75}", fmtM(revAgg.p75))
        .replace("{n}", String(revAgg.n));
    }
    if (rank != null && Number.isFinite(rank)) {
      sectorPeerRankLine = REPORT.sectorPeerRevenueRank.replace(
        "{pct}",
        String(rank)
      );
    }
  } catch {
    /* ignore */
  }
}

const byTicker = idx.byTicker as Record<
  string,
  { ticker: string; name: string; sector: string }
>;
const sectorPeers = Object.values(byTicker)
  .filter((c) => c.sector === meta.sector && c.ticker !== meta.ticker)
  .sort((a, b) => a.ticker.localeCompare(b.ticker))
  .slice(0, 18);

const pageTitle = `${meta.ticker} ${meta.name} — ${SITE.name}`;
const pageDesc = `${meta.ticker} ${meta.name} · ${meta.sector} — Taiwan coverage (中文 / EN UI)`;
---
<Layout title={pageTitle} description={pageDesc}>
  <div class="breadcrumb" aria-label="Breadcrumb">
    <a href="/"><Bi zh="首頁" en="Home" /></a>
    <span class="bc-sep"> / </span>
    <a href="/sectors"><Bi zh="產業" en="Industries" /></a>
    <span class="bc-sep"> / </span>
    <a href={`/sectors/${meta.sectorSlug}`}>{meta.sector}</a>
    <span class="bc-sep"> / </span>
    <span>{meta.ticker}</span>
  </div>

  <header class="report-hero">
    <div class="report-hero-main">
      <h1 class="report-title">{meta.ticker}<span class="dot">·</span>{meta.name}</h1>
      <p class="report-sector-line">
        {
          listingBadge && (
            <span
              class:list={[
                "report-listing-pill",
                `report-listing-pill--${listingBadge.variant}`,
              ]}
            >
              {listingBadge.label}
            </span>
          )
        }
        <span class="report-sector-pill">{meta.sector}</span>
        <span class="report-sector-en" lang="en">GICS-style industry</span>
      </p>
    </div>
  </header>

  <section class="meta-card-grid" aria-label={REPORT.summaryAria}>
    <div class="meta-card" data-meta="sector">
      <span class="meta-card-label">
        <Bi zh="板塊" en="Sector" />
      </span>
      <span class="meta-card-value">{sectorDisplay}</span>
    </div>
    <div class="meta-card" data-meta="industry">
      <span class="meta-card-label">
        <Bi zh="產業" en="Industry" />
      </span>
      <span class="meta-card-value">{industryDisplay}</span>
    </div>
    {summary.marketCap && (
      <div class="meta-card" data-meta="mcap">
        <span class="meta-card-label">
          <Bi zh="市值" en="Market cap" />
        </span>
        <span class="meta-card-value">{summary.marketCap}</span>
      </div>
    )}
    {summary.enterpriseValue && (
      <div class="meta-card" data-meta="ev">
        <span class="meta-card-label">
          <Bi zh="企業價值" en="Enterprise value" />
        </span>
        <span class="meta-card-value">{summary.enterpriseValue}</span>
      </div>
    )}
    {summary.note && (
      <div class="meta-card meta-card-wide" data-meta="note">
        <span class="meta-card-label">
          <Bi zh="備註" en="Note" />
        </span>
        <span class="meta-card-value">{summary.note}</span>
      </div>
    )}
  </section>

  {
    businessIntroMd && (
      <BusinessIntroCard
        markdownFull={businessIntroMd}
        nameToTicker={nameToTicker}
        labelToWikiSlug={labelToWikiSlug}
        revenueMix={revenueMix}
      />
    )
  }

  <ValuationSection ticker={meta.ticker} valuation={valuation} />

  {
    finDataUnavailable && (
      <p class="report-fin-data-unavailable" role="status">
        本檔財務數據暫無法取得，可能因資料源尚未覆蓋或公司近期有重大變動。
      </p>
    )
  }

  <QuoteStrip ticker={meta.ticker} />

  <RelationSummary
    blocks={relationBlocks}
    revenueStructure={revenueStructureForRelation}
    nameToTicker={nameToTicker}
    labelToWikiSlug={labelToWikiSlug}
  />

  {finDashOk && financialsJson && (
    <FinancialDashboard
      financialsJson={financialsJson}
      companyName={meta.name}
      ticker={meta.ticker}
      industryType={finDashIndustryType}
    />
  )}

  {!finDashOk && (
  <div class="report-charts-grid">
    {
      showJsonAnnualRev && jsonAnnualChart && jsonRevGrowth && (
        <RevenueChartToggle
          titleAbs={REPORT.annualRevTitle}
          titleGrowth={REPORT.annualRevGrowthTitle}
          ariaAbs={REPORT.annualRevAria}
          ariaGrowth={REPORT.annualRevGrowthAria}
          toggleLabel={REPORT.chartRevenueToggleLabel}
          labels={jsonAnnualChart.labels}
          absValues={jsonAnnualChart.values}
          growthValues={jsonRevGrowth}
          absMax={jsonRevMax}
          growthMax={jsonRevGrowthMax}
          periodFormat="annual"
        />
      )
    }
    {
      showJsonAnnualRev && jsonAnnualChart && !jsonRevGrowth && (
        <ChartBars
          titleBi={REPORT.annualRevTitle}
          ariaLabel={REPORT.annualRevAria}
          labels={jsonAnnualChart.labels}
          values={jsonAnnualChart.values}
          maxScale={jsonRevMax}
          kind="revenue"
          denseAxis={jsonAnnualChart.labels.length >= 9}
          periodFormat="annual"
        />
      )
    }
    {
      showMarkdownAnnualRev && revChronoChart && annRevGrowth && (
        <RevenueChartToggle
          titleAbs={REPORT.annualRevTitle}
          titleGrowth={REPORT.annualRevGrowthTitle}
          ariaAbs={REPORT.annualRevAria}
          ariaGrowth={REPORT.annualRevGrowthAria}
          toggleLabel={REPORT.chartRevenueToggleLabel}
          labels={revChronoChart.labels}
          absValues={revChronoChart.values}
          growthValues={annRevGrowth}
          absMax={revMax}
          growthMax={annRevGrowthMax}
          periodFormat="annual"
        />
      )
    }
    {
      showMarkdownAnnualRev && revChronoChart && !annRevGrowth && (
        <ChartBars
          titleBi={REPORT.annualRevTitle}
          ariaLabel={REPORT.annualRevAria}
          labels={revChronoChart.labels}
          values={revChronoChart.values}
          maxScale={revMax}
          kind="revenue"
          denseAxis={revChronoChart.labels.length >= 9}
          periodFormat="annual"
        />
      )
    }
    {
      quarterlyRevChartOk && qRevGrowth && (
        <RevenueChartToggle
          titleAbs={REPORT.quarterlyRevTitle}
          titleGrowth={REPORT.quarterlyRevGrowthTitle}
          ariaAbs={REPORT.quarterlyRevAria}
          ariaGrowth={REPORT.quarterlyRevGrowthAria}
          toggleLabel={REPORT.chartRevenueToggleLabel}
          labels={chartQuarterlyRev!.labels}
          absValues={chartQuarterlyRev!.values}
          growthValues={qRevGrowth}
          absMax={qRevMax}
          growthMax={qRevGrowthMax}
          periodFormat="quarterly"
        />
      )
    }
    {
      quarterlyRevChartOk && !qRevGrowth && (
        <ChartBars
          titleBi={REPORT.quarterlyRevTitle}
          ariaLabel={REPORT.quarterlyRevAria}
          labels={chartQuarterlyRev!.labels}
          values={chartQuarterlyRev!.values}
          maxScale={qRevMax}
          kind="revenue"
          denseAxis={chartQuarterlyRev!.labels.length >= 9}
          periodFormat="quarterly"
        />
      )
    }
    {
      annGmChronoChart && annGmChronoChart.values.length > 0 && annGmPpt && (
        <MarginChartToggle
          titleAbs={REPORT.annualGmTitle}
          titlePpt={REPORT.annualGmPptTitle}
          ariaAbs={REPORT.annualGmAria}
          ariaPpt={REPORT.annualGmPptAria}
          toggleLabel={REPORT.chartMarginToggleLabel}
          labels={annGmChronoChart.labels}
          absValues={annGmChronoChart.values}
          pptValues={annGmPpt}
          absMax={annGmMax}
          pptMax={annGmPptMax}
          periodFormat="annual"
        />
      )
    }
    {
      annGmChronoChart && annGmChronoChart.values.length > 0 && !annGmPpt && (
        <ChartBars
          titleBi={REPORT.annualGmTitle}
          ariaLabel={REPORT.annualGmAria}
          labels={annGmChronoChart.labels}
          values={annGmChronoChart.values}
          maxScale={annGmMax}
          kind="margin"
          denseAxis={annGmChronoChart.labels.length >= 9}
          periodFormat="annual"
        />
      )
    }
    {
      quarterlyGmChartOk && qGmPpt && (
        <MarginChartToggle
          titleAbs={REPORT.quarterlyGmTitle}
          titlePpt={REPORT.quarterlyGmPptTitle}
          ariaAbs={REPORT.quarterlyGmAria}
          ariaPpt={REPORT.quarterlyGmPptAria}
          toggleLabel={REPORT.chartMarginToggleLabel}
          labels={chartQuarterlyGm!.labels}
          absValues={chartQuarterlyGm!.values}
          pptValues={qGmPpt}
          absMax={qGmMax}
          pptMax={qGmPptMax}
          periodFormat="quarterly"
        />
      )
    }
    {
      quarterlyGmChartOk && !qGmPpt && (
        <ChartBars
          titleBi={REPORT.quarterlyGmTitle}
          ariaLabel={REPORT.quarterlyGmAria}
          labels={chartQuarterlyGm!.labels}
          values={chartQuarterlyGm!.values}
          maxScale={qGmMax}
          kind="margin"
          denseAxis={chartQuarterlyGm!.labels.length >= 9}
          periodFormat="quarterly"
        />
      )
    }
  </div>
  )}

  <div class="report-layout">
    <aside class="report-aside">
      {toc.length > 0 && (
        <nav class="toc-nav" aria-label={REPORT.tocTitle}>
          <h2 class="aside-title">{REPORT.tocTitle}</h2>
          <ul>
            {toc.map((item) => (
              <li class:list={[`depth-${item.depth}`]}>
                <a href={`#${item.id}`}>{item.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}
      {relatedTw.length > 0 && (
        <nav class="related-nav" aria-label={REPORT.relatedTitle}>
          <h2 class="aside-title">{REPORT.relatedTitle}</h2>
          <ul>
            {relatedTw.map((r) => (
              <li>
                <a href={`/report/${r.ticker}`}>
                  <strong>{r.ticker}</strong> {r.name}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}
      {sectorPeers.length > 0 && (
        <nav class="peers-nav" aria-label={REPORT.peersTitle}>
          <h2 class="aside-title">{REPORT.peersTitle}</h2>
          <ul class="peer-list">
            {sectorPeers.map((p) => (
              <li>
                <a href={`/report/${p.ticker}`}>
                  {p.ticker} {p.name}
                </a>
              </li>
            ))}
          </ul>
          <a class="aside-cta peers-more" href={`/sectors/${meta.sectorSlug}`}>
            {REPORT.peersMore}
          </a>
        </nav>
      )}
      {(sectorPeerHintLine || sectorPeerRankLine) && (
        <section class="sector-stats-aside" aria-label="Sector context">
          {sectorPeerHintLine && <p class="aside-hint">{sectorPeerHintLine}</p>}
          {sectorPeerRankLine && <p class="aside-hint">{sectorPeerRankLine}</p>}
        </section>
      )}
      <div class="aside-links">
        <a href="/graph" class="aside-cta">{REPORT.graphCta}</a>
        <p class="aside-hint">{REPORT.graphHint}</p>
      </div>
    </aside>
    <article
      class="report-body report-body-padded"
      data-fin-table-enhanced
      data-fin-table-hint={REPORT.finTableKeyHint}
      data-fin-table-mode-amount-label={REPORT.finTableModeAmount}
      data-fin-table-mode-pct-label={REPORT.finTableModePct}
      data-fin-table-mode-aria={REPORT.finTableModeAria}
      data-fin-table-consolidation-single-label={REPORT.finTableConsolidationSingle}
      data-fin-table-consolidation-ytd-label={REPORT.finTableConsolidationYtd}
      data-fin-table-consolidation-aria={REPORT.finTableConsolidationAria}
      data-fin-quarterly-ytd-json={quarterlyYtdJsonForTable}
      data-fin-quarterly-json={quarterlyJsonForReportTable}
      data-fin-quarterly-display-json={quarterlyDisplayJsonForTable}
      data-fin-annual-json={annualJsonForTable}
      data-fin-industry-type={finDashIndustryType}
      set:html={html}
    />
  </div>
  <script is:inline src="/scripts/report-financial-tables.js"></script>
</Layout>
