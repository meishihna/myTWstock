---
import { formatPercent, formatRevenueShort } from "../lib/parseReport";

interface Props {
  titleBi: string;
  ariaLabel: string;
  labels: string[];
  values: number[];
  maxScale: number;
  kind: "revenue" | "margin";
}
const { titleBi, ariaLabel, labels, values, maxScale, kind } = Astro.props;

const fmt = (v: number) =>
  kind === "revenue" ? formatRevenueShort(v) : formatPercent(v);

/** 表頭多為 YYYY-MM-DD → 單行 2025/03/31，較易一眼讀完 */
function formatAxisPeriodLabel(label: string | undefined): string {
  if (!label?.trim()) return "";
  const s = label.trim();
  const m = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (m) return `${m[1]}/${m[2]}/${m[3]}`;
  return s;
}

/** 固定軌道高度（px），柱高用像素計算，避免 % 在 flex 內無參考高度而壓成細線 */
const TRACK_H = 152;
const barPx = (v: number) => {
  const h = (Math.abs(v) / maxScale) * TRACK_H;
  return Math.max(kind === "revenue" ? 6 : 5, Math.round(h));
};
---

<section class="revenue-chart-section chart-block" aria-label={ariaLabel}>
  <h2 class="section-heading">{titleBi}</h2>
  <div class="revenue-bars" role="img" aria-label={ariaLabel}>
    {
      values.map((v, i) => {
        const full = labels[i] ?? "";
        const shown = formatAxisPeriodLabel(full);
        return (
        <div class="revenue-bar-wrap">
          <div class="revenue-bar-track" style={`height: ${TRACK_H}px`}>
            <div
              class:list={["revenue-bar", kind === "margin" && "revenue-bar--margin"]}
              style={`height: ${barPx(v)}px`}
              title={`${full}: ${fmt(v)}`}
            />
          </div>
          <span class="revenue-bar-label" title={`${full} · ${fmt(v)}`}>
            {shown}
          </span>
          <span class="revenue-bar-val">{fmt(v)}</span>
        </div>
        );
      })
    }
  </div>
</section>
