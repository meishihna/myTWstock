---
import type { FinancialsJson, IndustryType } from "../lib/financialsJson";
import {
  areaFillUnderLineD,
  bestQuarterlyBlock,
  buildAnnualKpis,
  computeLineGeometry,
  DASHBOARD_ANNUAL_MAX_PERIODS,
  DASHBOARD_QUARTERLY_MAX_PERIODS,
  linePathD,
  tailBlock,
  withAnnualEpsFromQuarterlySum,
  type TailedBlock,
} from "../lib/financialDashboard";
import {
  getIndustryConfig,
  REVENUE_LINE_COLORS,
  REVENUE_LINE_DASHES,
  REVENUE_LINE_LABELS,
  MARGIN_LINE_COLORS,
  MARGIN_LINE_DASHES,
  MARGIN_LINE_LABELS,
} from "../lib/industryConfig";

interface Props {
  financialsJson: FinancialsJson;
  companyName: string;
  ticker: string;
  industryType?: IndustryType | string;
}

const { financialsJson, companyName, ticker, industryType } = Astro.props;
const indCfg = getIndustryConfig(industryType);

const CHART_W = 920;
const CHART_H = 300;
/**
 * 左側預留固定寬度給 Y 軸（大位數、EPS「元」等），所有圖共用同一 PAD，
 * 縱軸與繪圖區左緣在畫面上才能對齊。
 */
const PAD = { l: 118, r: 28, t: 32, b: 52 };

const annual = withAnnualEpsFromQuarterlySum(
  tailBlock(financialsJson.annual, DASHBOARD_ANNUAL_MAX_PERIODS, "year")!,
  financialsJson
);
const qSrc = bestQuarterlyBlock(financialsJson);
const quarterly = qSrc
  ? tailBlock(qSrc, DASHBOARD_QUARTERLY_MAX_PERIODS)
  : null;

const annualKpis = buildAnnualKpis(annual, financialsJson.valuation, industryType);

type LineSpec = {
  name: string;
  values: (number | null)[];
  color: string;
  strokeDasharray?: string;
};

function lineChartSvg(
  xLabels: string[],
  specs: LineSpec[],
  unit: string,
  title: string,
  includeZero = true,
  opts?: { fillFirstSeriesArea?: boolean }
) {
  const seriesList = specs.map((s) => ({ values: s.values }));
  const geo = computeLineGeometry(
    xLabels,
    seriesList,
    CHART_W,
    CHART_H,
    PAD,
    { includeZero }
  );
  const { x, y, minY, maxY } = geo;
  const bottomY = y(minY);
  const revenueFillD =
    opts?.fillFirstSeriesArea && specs[0]
      ? areaFillUnderLineD(specs[0].values, x, y, bottomY)
      : undefined;
  const pointDots = specs.map((s) => {
    const arr: { cx: number; cy: number; color: string }[] = [];
    for (let i = 0; i < s.values.length; i++) {
      const v = s.values[i];
      if (v == null || !Number.isFinite(v)) continue;
      arr.push({ cx: x(i), cy: y(v), color: s.color });
    }
    return arr;
  });
  const paths = specs.map((s) => ({
    d: linePathD(s.values, x, y),
    color: s.color,
    strokeDasharray: s.strokeDasharray,
    name: s.name,
  }));
  const yTicks = 4;
  const tickVals: number[] = [];
  for (let i = 0; i <= yTicks; i++) {
    tickVals.push(minY + ((maxY - minY) * i) / yTicks);
  }
  const valueFormat = unit === "%" ? "pct" : "int";
  const tooltipSpec = {
    kind: "line" as const,
    valueFormat,
    xLabels,
    series: specs.map((s) => ({ name: s.name, color: s.color, values: s.values })),
    minY,
    maxY,
    pad: PAD,
    w: CHART_W,
    h: CHART_H,
  };
  return {
    paths,
    xLabels,
    minY,
    maxY,
    tickVals,
    y,
    unit,
    title,
    revenueFillD,
    pointDots,
    tooltipSpec,
  };
}

const annRevProfit = lineChartSvg(
  annual.xLabels,
  indCfg.revenueSeries.map((key) => ({
    name: REVENUE_LINE_LABELS[key] ?? key,
    values: annual.series[key] ?? [],
    color: REVENUE_LINE_COLORS[key] ?? "#888",
    strokeDasharray: REVENUE_LINE_DASHES[key],
  })),
  "百萬元",
  "營收與獲利",
  true,
  { fillFirstSeriesArea: true }
);

const annMargins = lineChartSvg(
  annual.xLabels,
  indCfg.marginSeries.map((key) => ({
    name: MARGIN_LINE_LABELS[key] ?? key,
    values: annual.series[key] ?? [],
    color: MARGIN_LINE_COLORS[key] ?? "#888",
    strokeDasharray: MARGIN_LINE_DASHES[key],
  })),
  "%",
  "利潤率趨勢",
  true
);

let annEpsBars: ReturnType<typeof barChartMillion> | null = null;

let qMargins: ReturnType<typeof lineChartSvg> | null = null;
let qRevGrouped: ReturnType<typeof groupedTwoSvg> | null = null;
let qRevSimple: ReturnType<typeof barChartMillion> | null = null;
let qNiBars: ReturnType<typeof barChartNetSigned> | null = null;
let qEpsBars: ReturnType<typeof barChartMillion> | null = null;
let qYoy: ReturnType<typeof lineChartSvg> | null = null;
let qExpenseStack: ReturnType<typeof stackedExpensePctSvg> | null = null;

const NEG_BAR = "#D85A30";

function barChartMillion(
  xLabels: string[],
  values: (number | null)[],
  title: string,
  barColor: string,
  barOpts?: {
    stroke?: string;
    fillOpacity?: number;
    tooltipFormat?: "eps" | "int";
    tooltipLabel?: string;
  }
) {
  const finite = values
    .map((v, i) => ({ v, i }))
    .filter((o) => o.v != null && Number.isFinite(o.v!)) as { v: number; i: number }[];
  let maxV = finite.length ? Math.max(...finite.map((o) => Math.abs(o.v)), 1) : 1;
  maxV *= 1.08;
  const hasNegative = values.some((v) => v != null && Number.isFinite(v) && v < 0);
  const innerW = CHART_W - PAD.l - PAD.r;
  const innerH = CHART_H - PAD.t - PAD.b;
  /** 含負值時零線置中，正／負各用半高，避免負柱超出圖底 */
  const plotHalf = hasNegative ? innerH / 2 : innerH;
  const baselineY = hasNegative ? PAD.t + plotHalf : PAD.t + innerH;
  const n = xLabels.length;
  const gap = 0.2;
  const bw = (innerW / n) * (1 - gap);
  const strokePos = barOpts?.stroke ?? barColor;
  const bars = values.map((v, i) => {
    if (v == null || !Number.isFinite(v)) return null;
    const h = (Math.abs(v) / maxV) * plotHalf;
    const x0 = PAD.l + (innerW * i) / n + (innerW / n - bw) / 2;
    const pos = v >= 0;
    const y0 = pos ? baselineY - h : baselineY;
    return {
      x: x0,
      y: y0,
      w: bw,
      h: Math.max(h, 2),
      v,
      fill: pos ? barColor : NEG_BAR,
      stroke: pos ? strokePos : NEG_BAR,
    };
  });
  const vf = barOpts?.tooltipFormat === "eps" ? "eps" : "int";
  const tooltipSpec = {
    kind: "simpleBar" as const,
    valueFormat: vf,
    valueLabel:
      barOpts?.tooltipLabel ??
      (barOpts?.tooltipFormat === "eps" ? "EPS" : "淨利"),
    xLabels,
    values,
    pad: PAD,
    w: CHART_W,
    h: CHART_H,
  };
  return {
    bars,
    xLabels,
    maxV,
    title,
    barColor,
    barStroke: strokePos,
    fillOpacity: barOpts?.fillOpacity ?? 0.55,
    innerH: innerH + PAD.t,
    tooltipSpec,
    baselineY,
    scaleMax: maxV,
    hasNegative,
  };
}

function barChartNetSigned(
  xLabels: string[],
  values: (number | null)[],
  chartTitle = "季度淨利（Quarterly net income）"
) {
  const innerW = CHART_W - PAD.l - PAD.r;
  const innerH = CHART_H - PAD.t - PAD.b;
  const n = xLabels.length;
  let maxV = 1;
  for (const v of values) {
    if (v != null && Number.isFinite(v)) maxV = Math.max(maxV, Math.abs(v));
  }
  maxV *= 1.08;
  const hasNegative = values.some((v) => v != null && Number.isFinite(v) && v < 0);
  const plotHalf = hasNegative ? innerH / 2 : innerH;
  const baselineY = hasNegative ? PAD.t + plotHalf : PAD.t + innerH;
  const gap = 0.2;
  const bw = (innerW / n) * (1 - gap);
  const bars = values.map((v, i) => {
    if (v == null || !Number.isFinite(v)) return null;
    const h = (Math.abs(v) / maxV) * plotHalf;
    const x0 = PAD.l + (innerW * i) / n + (innerW / n - bw) / 2;
    const pos = v >= 0;
    const y0 = pos ? baselineY - h : baselineY;
    return {
      x: x0,
      y: y0,
      w: bw,
      h: Math.max(h, 2),
      fill: pos ? "#7F77DD" : "#D85A30",
      fillOpacity: 0.33,
      stroke: pos ? "#7F77DD" : "#D85A30",
    };
  });
  const rawVals = values;
  const tooltipSpec = {
    kind: "signedBar" as const,
    xLabels,
    values: rawVals,
    pad: PAD,
    w: CHART_W,
    h: CHART_H,
  };
  return {
    bars,
    xLabels,
    n,
    title: chartTitle,
    baselineY,
    scaleMax: maxV,
    hasNegative,
    tooltipSpec,
  };
}

function seriesHasFinite(row: (number | null)[] | undefined): boolean {
  return Boolean(row?.some((v) => v != null && Number.isFinite(v)));
}

if (seriesHasFinite(annual.series.EPS)) {
  annEpsBars = barChartMillion(
    annual.xLabels,
    annual.series.EPS ?? [],
    "年度 EPS（Annual EPS）",
    "#BA7517",
    { stroke: "#BA7517", fillOpacity: 0.35, tooltipFormat: "eps" as const, tooltipLabel: "EPS" }
  );
}

/** 三項費用占營收％堆疊柱（由底而上：推銷、研發、管理） */
function stackedExpensePctSvg(
  xLabels: string[],
  revenue: (number | null)[],
  selling: (number | null)[],
  rd: (number | null)[],
  ga: (number | null)[]
) {
  const n = xLabels.length;
  const segA: (number | null)[] = [];
  const segB: (number | null)[] = [];
  const segC: (number | null)[] = [];
  let maxSum = 1;
  for (let i = 0; i < n; i++) {
    const r = revenue[i];
    if (r == null || !Number.isFinite(r) || r <= 0) {
      segA.push(null);
      segB.push(null);
      segC.push(null);
      continue;
    }
    const s = selling[i];
    const d = rd[i];
    const g = ga[i];
    const pa = s != null && Number.isFinite(s) ? (s / r) * 100 : 0;
    const pb = d != null && Number.isFinite(d) ? (d / r) * 100 : 0;
    const pc = g != null && Number.isFinite(g) ? (g / r) * 100 : 0;
    segA.push(pa);
    segB.push(pb);
    segC.push(pc);
    maxSum = Math.max(maxSum, pa + pb + pc);
  }
  maxSum *= 1.1;
  const innerW = CHART_W - PAD.l - PAD.r;
  const innerH = CHART_H - PAD.t - PAD.b;
  const slot = innerW / n;
  const bw = slot * 0.55;
  const baseY = PAD.t + innerH;
  type Rect = { x: number; y: number; w: number; h: number; fill: string };
  const stackRects: Rect[] = [];
  const categoryCenterX: number[] = [];
  for (let i = 0; i < n; i++) {
    const x0 = PAD.l + i * slot + (slot - bw) / 2;
    categoryCenterX.push(x0 + bw / 2);
    const a = segA[i];
    const b = segB[i];
    const c = segC[i];
    if (a == null || b == null || c == null) continue;
    let yCur = baseY;
    const layers = [
      { pct: a, fill: "#378ADD" },
      { pct: b, fill: "#D85A30" },
      { pct: c, fill: "#888780" },
    ];
    for (const { pct, fill } of layers) {
      if (!(pct > 0)) continue;
      const h = (pct / maxSum) * innerH;
      const yTop = yCur - h;
      stackRects.push({ x: x0, y: yTop, w: bw, h: Math.max(h, 1), fill });
      yCur = yTop;
    }
  }
  const tickVals = Array.from({ length: 5 }, (_, i) => (maxSum * i) / 4);
  const tooltipSpec = {
    kind: "stackedBar" as const,
    xLabels,
    segments: [
      { name: "推銷費用率", color: "#378ADD", values: segA.map((v) => (v == null ? null : v)) },
      { name: "研發費用率", color: "#D85A30", values: segB.map((v) => (v == null ? null : v)) },
      { name: "管理費用率", color: "#888780", values: segC.map((v) => (v == null ? null : v)) },
    ],
    pad: PAD,
    w: CHART_W,
    h: CHART_H,
    categoryCenterX,
  };
  return {
    xLabels,
    stackRects,
    maxSum,
    baseY,
    tickVals,
    title: "費用結構（占營收％）",
    tooltipSpec,
  };
}

function yoyPctSeries(vals: (number | null)[], lag: number): (number | null)[] {
  return vals.map((v, i) => {
    if (i < lag) return null;
    const prev = vals[i - lag];
    if (v == null || prev == null || !Number.isFinite(v) || !Number.isFinite(prev)) return null;
    if (prev === 0) return null;
    return ((v / prev - 1) * 100);
  });
}

function groupedTwoSvg(
  xLabels: string[],
  a: (number | null)[],
  b: (number | null)[],
  title: string,
  nameA: string,
  nameB: string,
  colorA = "#378ADD",
  colorB = "#D85A30"
) {
  const innerW = CHART_W - PAD.l - PAD.r;
  const innerH = CHART_H - PAD.t - PAD.b;
  const n = xLabels.length;
  let maxV = 1;
  for (let i = 0; i < n; i++) {
    const va = a[i];
    const vb = b[i];
    if (va != null && Number.isFinite(va)) maxV = Math.max(maxV, Math.abs(va));
    if (vb != null && Number.isFinite(vb)) maxV = Math.max(maxV, Math.abs(vb));
  }
  maxV *= 1.08;
  const hasNegative =
    a.some((v) => v != null && Number.isFinite(v) && v < 0) ||
    b.some((v) => v != null && Number.isFinite(v) && v < 0);
  const plotHalf = hasNegative ? innerH / 2 : innerH;
  const zeroY = hasNegative ? PAD.t + plotHalf : PAD.t + innerH;
  const slot = innerW / n;
  const w = slot * 0.32;
  const bars: { x: number; y: number; w: number; h: number; v: number; color: string }[] = [];
  const categoryCenterX: number[] = [];
  for (let i = 0; i < n; i++) {
    const baseX = PAD.l + i * slot + slot * 0.1;
    let left = Infinity;
    let right = -Infinity;
    const ocf = a[i];
    const cx = baseX;
    if (ocf != null && Number.isFinite(ocf)) {
      const h = (Math.abs(ocf) / maxV) * plotHalf;
      const pos = ocf >= 0;
      const y0 = pos ? zeroY - h : zeroY;
      bars.push({ x: cx, y: y0, w, h, v: ocf, color: colorA });
      left = Math.min(left, cx);
      right = Math.max(right, cx + w);
    }
    const capex = b[i];
    const cx2 = baseX + w + slot * 0.06;
    if (capex != null && Number.isFinite(capex)) {
      const h = (Math.abs(capex) / maxV) * plotHalf;
      const pos = capex >= 0;
      const y0 = pos ? zeroY - h : zeroY;
      bars.push({ x: cx2, y: y0, w, h, v: capex, color: colorB });
      left = Math.min(left, cx2);
      right = Math.max(right, cx2 + w);
    }
    const slotMid = PAD.l + (i + 0.5) * slot;
    categoryCenterX.push(left !== Infinity ? (left + right) / 2 : slotMid);
  }
  const tooltipSpec = {
    kind: "groupedBar" as const,
    valueFormat: "int" as const,
    xLabels,
    series: [
      { name: nameA, color: colorA, values: [...a] },
      { name: nameB, color: colorB, values: [...b] },
    ],
    pad: PAD,
    w: CHART_W,
    h: CHART_H,
    categoryCenterX,
  };
  return {
    bars,
    xLabels,
    maxV,
    title,
    nameA,
    nameB,
    innerH: innerH + PAD.t,
    innerW,
    n,
    tooltipSpec,
    hasNegative,
    zeroY,
    scaleMax: maxV,
  };
}

if (quarterly) {
  const gpRow = quarterly.series["Gross Profit"];
  const hasGp = seriesHasFinite(gpRow);
  if (hasGp) {
    qRevGrouped = groupedTwoSvg(
      quarterly.xLabels,
      quarterly.series.Revenue ?? [],
      gpRow ?? [],
      "季度營收與毛利（Quarterly revenue & gross profit）",
      REVENUE_LINE_LABELS.Revenue ?? "營收",
      REVENUE_LINE_LABELS["Gross Profit"] ?? "毛利",
      REVENUE_LINE_COLORS.Revenue ?? "#378ADD",
      REVENUE_LINE_COLORS["Gross Profit"] ?? "#1D9E75"
    );
  } else {
    qRevSimple = barChartMillion(
      quarterly.xLabels,
      quarterly.series.Revenue ?? [],
      "季度營收（Quarterly revenue）",
      "#378ADD",
      { stroke: "#378ADD", fillOpacity: 0.4, tooltipLabel: "營收（百萬）" }
    );
  }

  const marginKeys = indCfg.marginSeries.filter((key) =>
    seriesHasFinite(quarterly.series[key])
  );
  if (marginKeys.length > 0) {
    qMargins = lineChartSvg(
      quarterly.xLabels,
      marginKeys.map((key) => ({
        name: MARGIN_LINE_LABELS[key] ?? key,
        values: quarterly.series[key] ?? [],
        color: MARGIN_LINE_COLORS[key] ?? "#888",
        strokeDasharray: MARGIN_LINE_DASHES[key],
      })),
      "%",
      "季度利潤率趨勢（Quarterly margin trends）",
      true
    );
  }

  qNiBars = barChartNetSigned(
    quarterly.xLabels,
    quarterly.series["Net Income"] ?? [],
    "季度淨利（Quarterly net income，百萬元）"
  );

  const qEpsRow = quarterly.series.EPS;
  if (seriesHasFinite(qEpsRow)) {
    qEpsBars = barChartMillion(
      quarterly.xLabels,
      qEpsRow ?? [],
      "季度 EPS（Quarterly EPS）",
      "#BA7517",
      { stroke: "#BA7517", fillOpacity: 0.35, tooltipFormat: "eps" as const, tooltipLabel: "EPS" }
    );
  }

  const rev = quarterly.series.Revenue ?? [];
  const ni = quarterly.series["Net Income"] ?? [];
  const eps = quarterly.series.EPS ?? [];
  const yoySpecs: LineSpec[] = [];
  const yRev = yoyPctSeries(rev, 4);
  if (seriesHasFinite(yRev)) {
    yoySpecs.push({
      name: "營收 YoY",
      values: yRev,
      color: "#378ADD",
    });
  }
  const yNi = yoyPctSeries(ni, 4);
  if (seriesHasFinite(yNi)) {
    yoySpecs.push({
      name: "淨利 YoY",
      values: yNi,
      color: "#7F77DD",
      strokeDasharray: "5 3",
    });
  }
  const yEps = yoyPctSeries(eps, 4);
  if (seriesHasFinite(yEps)) {
    yoySpecs.push({
      name: "EPS YoY",
      values: yEps,
      color: "#BA7517",
      strokeDasharray: "2 2",
    });
  }
  if (yoySpecs.length > 0) {
    qYoy = lineChartSvg(
      quarterly.xLabels,
      yoySpecs,
      "%",
      "同比成長率 YoY（Year-over-year growth）",
      true,
      { fillFirstSeriesArea: false }
    );
  }

  const expKeys = [
    "Selling & Marketing Exp",
    "R&D Exp",
    "General & Admin Exp",
  ] as const;
  const showExpenseStack = expKeys.every((k) => !indCfg.hiddenMetricRows.has(k));
  if (showExpenseStack) {
    const sRow = quarterly.series["Selling & Marketing Exp"];
    const rRow = quarterly.series["R&D Exp"];
    const gRow = quarterly.series["General & Admin Exp"];
    if (seriesHasFinite(sRow) || seriesHasFinite(rRow) || seriesHasFinite(gRow)) {
      qExpenseStack = stackedExpensePctSvg(
        quarterly.xLabels,
        quarterly.series.Revenue ?? [],
        sRow ?? [],
        rRow ?? [],
        gRow ?? []
      );
    }
  }
}

const fmtM = (n: number) => n.toLocaleString("zh-TW", { maximumFractionDigits: 0 });
const INNER_H = CHART_H - PAD.t - PAD.b;
const PLOT_BOTTOM = CHART_H - PAD.b;
const PLOT_R = CHART_W - PAD.r;

function linearBarTicks(maxV: number, steps = 4): number[] {
  if (!maxV || !Number.isFinite(maxV)) return [0];
  return Array.from({ length: steps + 1 }, (_, i) => (maxV * i) / steps);
}

const qRevGroupedYTickMarks =
  qRevGrouped == null
    ? []
    : qRevGrouped.hasNegative
      ? [-1, -0.5, 0, 0.5, 1].map((frac) => {
          const v = frac * qRevGrouped.scaleMax;
          const yy = qRevGrouped.zeroY - (v / qRevGrouped.scaleMax) * (INNER_H / 2);
          return { v, yy };
        })
      : linearBarTicks(qRevGrouped.maxV).map((tv) => ({
          v: tv,
          yy: PLOT_BOTTOM - (tv / qRevGrouped.maxV) * INNER_H,
        }));

const qRevSimpleHalfSpan = qRevSimple?.hasNegative ? INNER_H / 2 : INNER_H;
const qRevSimpleYTickMarks =
  qRevSimple == null
    ? []
    : qRevSimple.hasNegative
      ? [-1, -0.5, 0, 0.5, 1].map((frac) => {
          const v = frac * qRevSimple.scaleMax;
          const yy = qRevSimple.baselineY - (v / qRevSimple.scaleMax) * qRevSimpleHalfSpan;
          return { v, yy };
        })
      : linearBarTicks(qRevSimple.maxV).map((tv) => ({
          v: tv,
          yy: PLOT_BOTTOM - (tv / qRevSimple.maxV) * INNER_H,
        }));

const qEpsHalfSpan = qEpsBars?.hasNegative ? INNER_H / 2 : INNER_H;
const qEpsYTickMarks =
  qEpsBars == null
    ? []
    : qEpsBars.hasNegative
      ? [-1, -0.5, 0, 0.5, 1].map((frac) => {
          const v = frac * qEpsBars.scaleMax;
          const yy = qEpsBars.baselineY - (v / qEpsBars.scaleMax) * qEpsHalfSpan;
          return { v, yy };
        })
      : linearBarTicks(qEpsBars.maxV).map((tv) => ({
          v: tv,
          yy: PLOT_BOTTOM - (tv / qEpsBars.maxV) * INNER_H,
        }));

const annEpsHalfSpan = annEpsBars?.hasNegative ? INNER_H / 2 : INNER_H;
const annEpsYTickMarks =
  annEpsBars == null
    ? []
    : annEpsBars.hasNegative
      ? [-1, -0.5, 0, 0.5, 1].map((frac) => {
          const v = frac * annEpsBars.scaleMax;
          const yy = annEpsBars.baselineY - (v / annEpsBars.scaleMax) * annEpsHalfSpan;
          return { v, yy };
        })
      : linearBarTicks(annEpsBars.maxV).map((tv) => ({
          v: tv,
          yy: PLOT_BOTTOM - (tv / annEpsBars.maxV) * INNER_H,
        }));

const kpiPrimary = annualKpis.primary;
const kpiSecondary = annualKpis.secondary;

/** Astro 模板內不可寫 <= 或 a < b，< 會被當成標籤 */
function noPositiveMax(maxV: number) {
  return !maxV || !(maxV > 0);
}

const qNiYTickMarks =
  qNiBars == null
    ? []
    : (() => {
        const span = qNiBars.hasNegative ? INNER_H / 2 : INNER_H;
        return [-1, -0.5, 0, 0.5, 1]
          .map((frac) => {
            const v = frac * qNiBars.scaleMax;
            const yy = qNiBars.baselineY - (v / qNiBars.scaleMax) * span;
            return { v, yy };
          })
          .filter((o) => o.yy >= PAD.t - 4 && o.yy <= PLOT_BOTTOM + 4);
