                  return (
                    <g>
                      <line class="fin-dash__grid" x1={PAD.l} y1={yy} x2={PLOT_R} y2={yy} />
                      <text class="fin-dash__ytick" x={PAD.l - 10} y={yy + 4} text-anchor="end">
                        {v.toFixed(2)} 元
                      </text>
                    </g>
                  );
                })}
                {qEpsBars.bars.map((b) =>
                  b ? (
                    <rect
                      x={b.x}
                      y={b.y}
                      width={b.w}
                      height={Math.max(b.h, 2)}
                      rx={3}
                      fill={b.fill}
                      fill-opacity={qEpsBars.fillOpacity}
                      stroke={b.stroke}
                      stroke-width="1.5"
                    />
                  ) : null
                )}
                {qEpsBars.xLabels.map((lab, i) => {
                  const slot = (CHART_W - PAD.l - PAD.r) / qEpsBars.xLabels.length;
                  const xi = PAD.l + slot * i + slot / 2;
                  const yTick = CHART_H - 12;
                  return (
                    <text
                      class="fin-dash__xtick fin-dash__xtick--dense"
                      x={xi}
                      y={yTick}
                      text-anchor="end"
                      transform={`rotate(-42 ${xi} ${yTick})`}
                    >
                      {lab}
                    </text>
                  );
                })}
              </svg>
              <script type="application/json" data-fin-chart-spec set:html={JSON.stringify(qEpsBars.tooltipSpec)} />
            </div>
          </figure>
        )}

        {qYoy && (
          <figure class="fin-dash__chart">
            <p class="fin-dash__sl">{qYoy.title}（{qYoy.unit}）</p>
            <ul class="fin-dash__legend">
              {qYoy.paths.map((p) => (
                <li>
                  <span class="fin-dash__leg-dot" style={`background:${p.color}`} />
                  {p.name}
                </li>
              ))}
            </ul>
            <div class="fin-dash__canvas-wrap fin-dash__canvas-wrap--mar">
              <svg class="fin-dash__svg" viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                <line class="fin-dash__axis-spine" x1={PAD.l} y1={PAD.t} x2={PAD.l} y2={PLOT_BOTTOM} />
                <line class="fin-dash__axis-spine" x1={PAD.l} y1={PLOT_BOTTOM} x2={PLOT_R} y2={PLOT_BOTTOM} />
                {qYoy.tickVals.map((tv) => {
                  const yy = qYoy.y(tv);
                  return (
                    <g>
                      <line class="fin-dash__grid" x1={PAD.l} x2={CHART_W - PAD.r} y1={yy} y2={yy} />
                      <text class="fin-dash__ytick" x={PAD.l - 10} y={yy + 4} text-anchor="end">
                        {tv.toFixed(1)}%
                      </text>
                    </g>
                  );
                })}
                {qYoy.paths.map((p) => (
                  <path
                    d={p.d}
                    fill="none"
                    stroke={p.color}
                    stroke-width="2"
                    stroke-dasharray={p.strokeDasharray}
                  />
                ))}
                {qYoy.pointDots.flatMap((dots) =>
                  dots.map((d) => <circle cx={d.cx} cy={d.cy} r="3.5" fill={d.color} />)
                )}
                {qYoy.xLabels.map((lab, i) => {
                  const xi = PAD.l + ((CHART_W - PAD.l - PAD.r) * i) / Math.max(1, qYoy.xLabels.length - 1);
                  const yTick = CHART_H - 12;
                  return (
                    <text
                      class="fin-dash__xtick fin-dash__xtick--dense"
                      x={xi}
                      y={yTick}
                      text-anchor="end"
                      transform={`rotate(-42 ${xi} ${yTick})`}
                    >
                      {lab}
                    </text>
                  );
                })}
              </svg>
              <script type="application/json" data-fin-chart-spec set:html={JSON.stringify(qYoy.tooltipSpec)} />
            </div>
          </figure>
        )}

        {qExpenseStack && (
          <figure class="fin-dash__chart">
            <p class="fin-dash__sl">{qExpenseStack.title}</p>
            <ul class="fin-dash__legend">
              <li><span class="fin-dash__leg-dot" style="background:#378ADD" />推銷費用率</li>
              <li><span class="fin-dash__leg-dot" style="background:#D85A30" />研發費用率</li>
              <li><span class="fin-dash__leg-dot" style="background:#888780" />管理費用率</li>
            </ul>
            <div class="fin-dash__canvas-wrap fin-dash__canvas-wrap--triple">
              <svg class="fin-dash__svg" viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                <line class="fin-dash__axis-spine" x1={PAD.l} y1={PAD.t} x2={PAD.l} y2={PLOT_BOTTOM} />
                <line class="fin-dash__axis-spine" x1={PAD.l} y1={PLOT_BOTTOM} x2={PLOT_R} y2={PLOT_BOTTOM} />
                {qExpenseStack.tickVals.map((tv) => {
                  const yy = qExpenseStack.baseY - (tv / qExpenseStack.maxSum) * INNER_H;
                  return (
                    <g>
                      <line class="fin-dash__grid" x1={PAD.l} x2={PLOT_R} y1={yy} y2={yy} />
                      <text class="fin-dash__ytick" x={PAD.l - 10} y={yy + 4} text-anchor="end">
                        {tv.toFixed(1)}%
                      </text>
                    </g>
                  );
                })}
                {qExpenseStack.stackRects.map((r) => (
                  <rect
                    x={r.x}
                    y={r.y}
                    width={r.w}
                    height={r.h}
                    rx={2}
                    fill={r.fill}
                    fill-opacity="0.85"
                    stroke={r.fill}
                    stroke-width="1"
                  />
                ))}
                {qExpenseStack.xLabels.map((lab, i) => {
                  const xi = qExpenseStack.tooltipSpec.categoryCenterX[i]!;
                  const yTick = CHART_H - 12;
                  return (
                    <text
                      class="fin-dash__xtick fin-dash__xtick--dense"
                      x={xi}
                      y={yTick}
                      text-anchor="end"
                      transform={`rotate(-42 ${xi} ${yTick})`}
                    >
                      {lab}
                    </text>
                  );
                })}
              </svg>
              <script type="application/json" data-fin-chart-spec set:html={JSON.stringify(qExpenseStack.tooltipSpec)} />
            </div>
          </figure>
        )}
        </div>
      </div>
    )
  }
</section>
</div>

<script is:inline src="/scripts/fin-dash-charts.js"></script>

<script>
  (function () {
    const root = document.querySelector("[data-fin-dash]");
    if (!root) return;
    const tabs = root.querySelectorAll("[data-fin-tab]");
    const panels = root.querySelectorAll("[data-fin-panel]");
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const key = tab.getAttribute("data-fin-tab");
        if (!key || tab.hasAttribute("disabled")) return;
        tabs.forEach((t) => {
          const on = t.getAttribute("data-fin-tab") === key;
          t.classList.toggle("is-active", on);
          t.setAttribute("aria-selected", on ? "true" : "false");
        });
        panels.forEach((p) => {
          const match = p.getAttribute("data-fin-panel") === key;
          p.classList.toggle("is-active", match);
          if (match) p.removeAttribute("hidden");
          else p.setAttribute("hidden", "");
        });
      });
    });
  })();
</script>
